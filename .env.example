# Server
PORT=3000
NODE_ENV=development

# Database (PostgreSQL) - Railway lo provee automaticamente como DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/mindreprogram

# JWT (genera secretos unicos con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=tu-secreto-super-seguro-aqui
JWT_REFRESH_SECRET=otro-secreto-para-refresh-tokens
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=30d

# Storage Mode: 'gdrive' para pruebas, 's3' para produccion
STORAGE_MODE=gdrive

# Stripe (modo test)
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
STRIPE_BASIC_PRICE_ID=price_xxxxx
STRIPE_PREMIUM_PRICE_ID=price_xxxxx
STRIPE_PRO_PRICE_ID=price_xxxxx

# PayPal (sandbox) - opcional para pruebas iniciales
PAYPAL_CLIENT_ID=xxxxx
PAYPAL_CLIENT_SECRET=xxxxx
PAYPAL_MODE=sandbox
PAYPAL_BASIC_PLAN_ID=P-xxxxx
PAYPAL_PREMIUM_PLAN_ID=P-xxxxx
PAYPAL_PRO_PLAN_ID=P-xxxxx

# AWS S3 (solo si STORAGE_MODE=s3)
AWS_ACCESS_KEY_ID=xxxxx
AWS_SECRET_ACCESS_KEY=xxxxx
AWS_REGION=us-east-1
AWS_S3_BUCKET=mindreprogram-meditations

# Telegram Bot (obtener de @BotFather en Telegram)
TELEGRAM_BOT_TOKEN=xxxxx:xxxxx

# URLs (actualizar con tu dominio de Railway)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
